# Repo-root .gitignore (each feature folder also has its own).

# Secrets — real credentials are NEVER committed. Each feature ships a
# credentials.example.json template; copy it to credentials.json and fill it in.
credentials.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# Virtual environments
venv/
.venv/
env/

# Test run artifacts
**/logs/
**/screenshots/
*.log

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
